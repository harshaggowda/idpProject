# ── Backend environment variables ────────────────────────────────
# Copy this file to ".env" (in the same backend/ folder) and fill in
# your real values. The .env file is gitignored, so your secrets stay
# off GitHub.

# MongoDB Atlas connection string.
# Get it from Atlas: Database > Connect > Drivers (Node.js).
# Replace <db_password> with your database user's password, and add
# the database name (e.g. "smartroad") before the "?".
# Example:
# MONGO_URI=mongodb+srv://smartroad_user:yourPassword@cluster0.abcde.mongodb.net/smartroad?retryWrites=true&w=majority
MONGO_URI=

# Port the backend listens on (optional, defaults to 5000)
PORT=5000

# ── AI Civic Report Generator (Gemini) ───────────────────────────
# Google AI Studio API key for Gemini. Get one (free tier available)
# at https://aistudio.google.com/apikey
# Used ONLY by backend/services/aiService.js to generate municipal
# road reports from aggregated analytics. If this is left blank, the
# /reports/generate endpoint still returns the analytics summary but
# the AI markdown report will be unavailable.
GEMINI_API_KEY=


# Optional: override the Gemini model (defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
